{
  "name": "@sourcards/skill-flashcards",
  "version": "0.1.0",
  "description": "SourCards Codex plugin / skill pack: formulate FSRS flashcards, lint JSON, and import via API. Primary skill: sourcards-flashcards. For Codex plugins, skills-manager, Claude Code, and other outer agents.",
  "type": "module",
  "license": "MIT",
  "files": [
    ".codex-plugin",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./skills/sourcards-flashcards/SKILL.md",
    "./package.json": "./package.json",
    "./SKILL.md": "./skills/sourcards-flashcards/SKILL.md",
    "./references/*": "./skills/sourcards-flashcards/references/*",
    "./scripts/*": "./skills/sourcards-flashcards/scripts/*",
    "./skills/*": "./skills/*"
  },
  "bin": {
    "sourcards-lint-cards": "./skills/sourcards-flashcards/scripts/lint-cards.mjs"
  },
  "scripts": {
    "test": "node skills/sourcards-flashcards/scripts/lint-cards.test.mjs",
    "lint-cards": "node skills/sourcards-flashcards/scripts/lint-cards.mjs"
  },
  "keywords": [
    "agent-skills",
    "claude",
    "codex",
    "codex-plugin",
    "flashcards",
    "fsrs",
    "plugin",
    "sourcards",
    "spaced-repetition"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2Lavine/skill-flashcards.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/2Lavine/skill-flashcards/issues"
  },
  "homepage": "https://github.com/2Lavine/skill-flashcards#readme"
}
